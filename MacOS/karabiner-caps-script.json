{
    "description": "Caps -> Left Option, Option+1/2 languages, Option+QWE/ASD/ZXC navigation",
    "manipulators": [
        {
            "from": {
                "key_code": "caps_lock",
                "modifiers": { "optional": ["any"] }
            },
            "to": [{ "key_code": "left_option" }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "1",
                "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                }
            },
            "to": [{ "select_input_source": { "input_source_id": "^org\\.sil\\.ukelele\\.keyboardlayout\\.unsavedukeleledocument2\\.english\\(c\\)$" } }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "2",
                "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                }
            },
            "to": [{ "select_input_source": { "input_source_id": "^org\\.sil\\.ukelele\\.keyboardlayout\\.unsavedukeleledocument2\\.russian\\(c\\)$" } }],
            "type": "basic"
        },
        {
            "from": {
                "key_code": "q",
                "modifiers": {
                    "mandatory": ["left_option"],
                    "optional": ["any"]
                }
            },
            "to": [{ "key_code": "home" }],
            "type": "basic"
        },
        {
            "from": {
